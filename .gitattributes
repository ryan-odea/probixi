# Normalize line endings: LF in the repo for all text, detected automatically.
* text=auto eol=lf

# Source and text formats are always LF.
*.py text eol=lf
*.pyi text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.bib text eol=lf
*.cff text eol=lf
*.geom text eol=lf
*.cell text eol=lf
*.lst text eol=lf

# Windows-only scripts keep their CRLF endings untouched (not normalized).
*.bat -text
*.cmd -text

# Binary assets: never touch.
*.png binary
*.gif binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.svg binary
*.h5 binary
*.cxi binary
*.duckdb binary
*.db binary
*.lock binary
